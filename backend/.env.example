# Copy to backend/.env and adjust. backend/.env is git-ignored.

# ── Auth / database (Milestone 2) ─────────────────────────────
# Local Postgres. Create the db first: createdb tradelens
DATABASE_URL=postgresql://localhost/tradelens
# Required for stable sessions. Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Seed admin account (used by seed.py; never hard-coded in source)
ADMIN_EMAIL=admin@tradelens.app
ADMIN_PASSWORD=

# Outgoing mail for verification / password-reset codes (Gmail SMTP).
# MAIL_APP_PASSWORD is a Google "app password" (Google Account → Security →
# 2-Step Verification → App passwords), NOT your Gmail login password.
# Leave unset to run without email — those endpoints then answer
# mail_not_configured and the UI shows a translated notice.
MAIL_USERNAME=
MAIL_APP_PASSWORD=
# MAIL_DEFAULT_SENDER=            # defaults to MAIL_USERNAME
# MAIL_SMTP_HOST=smtp.gmail.com
# MAIL_SMTP_PORT=587

# Google OAuth (optional until you create credentials in Google Cloud Console).
# Authorized redirect URI must be exactly:
#   http://127.0.0.1:5001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://127.0.0.1:5001/api/auth/google/callback

# Where to send the browser after OAuth completes. Keep on 127.0.0.1 —
# the session cookie is host-scoped, so open the app at http://127.0.0.1:5173.
# FRONTEND_URL=http://127.0.0.1:5173

# ── IB Gateway / TWS socket ───────────────────────────────────
IB_HOST=127.0.0.1
# 4001 = IB Gateway live, 4002 = IB Gateway paper, 7496 = TWS live, 7497 = TWS paper
IB_PORT=4001
# Any unused client id; must not collide with another connected API client
IB_CLIENT_ID=101
IB_CONNECT_TIMEOUT=8

# ── Flask ─────────────────────────────────────────────────────
FLASK_PORT=5001
# Comma-separated origins allowed by CORS (the Vite dev server)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
